# InfluxDB credentials — change these before deploying
DOCKER_INFLUXDB_INIT_USERNAME=admin
DOCKER_INFLUXDB_INIT_PASSWORD=change-me-to-a-strong-password
DOCKER_INFLUXDB_INIT_ADMIN_TOKEN=change-me-to-a-random-token
DOCKER_INFLUXDB_INIT_ORG=geodash
DOCKER_INFLUXDB_INIT_BUCKET=redalerts

# App settings
INFLUX_TOKEN=change-me-to-a-random-token
INFLUX_ORG=geodash
INFLUX_BUCKET=redalerts
POLL_INTERVAL=3
