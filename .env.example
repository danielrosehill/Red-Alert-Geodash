# InfluxDB settings
INFLUX_TOKEN=geodash-dev-token
INFLUX_ORG=geodash
INFLUX_BUCKET=redalerts
INFLUXDB_ADMIN_USER=admin
INFLUXDB_ADMIN_PASSWORD=geodash-admin-pw

# Ports (optional — defaults shown)
GEODASH_PORT=8083
INFLUXDB_PORT=8086

# Poll interval (seconds)
POLL_INTERVAL=3

# Oref Alert Proxy — set if running alongside the Red Alert Monitoring Stack
# When set, Geodash reads alerts from the proxy instead of polling Oref directly.
# OREF_PROXY_URL=http://oref-proxy:8764

# Backup settings (optional — for nightly-backup.sh)
# BACKUP_S3_BUCKET=s3://your-backup-bucket
# BACKUP_AWS_PROFILE=default
